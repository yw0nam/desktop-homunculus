{
  "name": "@hmcs/character-settings",
  "version": "0.1.0-alpha.5",
  "description": "Character settings panel mod that provides a WebView UI to configure individual character preferences",
  "license": "MIT",
  "type": "module",
  "author": "notelm",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui",
    "test": "vitest run"
  },
  "homunculus": {
    "menus": [
      {
        "id": "open-character-settings",
        "text": "Character Settings",
        "command": "open-ui"
      }
    ],
    "assets": {
      "character-settings:ui": {
        "path": "ui/dist/index.html",
        "type": "html",
        "description": "Character settings panel UI"
      }
    }
  },
  "bin": {
    "open-ui": "commands/open-ui.ts"
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "happy-dom": "^17.4.7",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.0.0"
  }
}
